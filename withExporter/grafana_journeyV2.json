{
  "title": "Synthetic Journey Monitoring (Production - Final)",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(synthetic_step_duration_s_count, env)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "run_id",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(synthetic_step_duration_s_count{env=~\"$env\"}, run_id)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [

    {
      "type": "stat",
      "title": "Overall Step P90 (Full Run)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum by (le) (increase(synthetic_step_duration_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[$__range])))"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Overall Step Avg (Full Run)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(synthetic_step_duration_s_sum{env=~\"$env\", run_id=~\"$run_id\"}[$__range])) / sum(increase(synthetic_step_duration_s_count{env=~\"$env\", run_id=~\"$run_id\"}[$__range]))"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Total Step Success",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(synthetic_journey_success_total{env=~\"$env\", run_id=~\"$run_id\"}[$__range]))"
        }
      ]
    },

    {
      "type": "stat",
      "title": "Total Step Failure",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(synthetic_journey_failure_total{env=~\"$env\", run_id=~\"$run_id\"}[$__range]))"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Step Average Trend",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(synthetic_step_duration_s_sum{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (journey, step) / sum(rate(synthetic_step_duration_s_count{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (journey, step)",
          "legendFormat": "{{journey}} - {{step}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Step P90 Trend",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(synthetic_step_duration_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (le, journey, step))",
          "legendFormat": "{{journey}} - {{step}}"
        }
      ]
    },

    {
      "type": "table",
      "title": "Top 10 Slowest Steps (P90 Full Run)",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, max by (journey, step) (histogram_quantile(0.9, sum by (le, journey, step) (increase(synthetic_step_duration_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[$__range])))))",
          "format": "table",
          "legendFormat": "{{journey}} - {{step}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Step FCP Trend",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(synthetic_step_fcp_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (le, journey, step))",
          "legendFormat": "{{journey}} - {{step}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Step LCP Trend",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(synthetic_step_lcp_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (le, journey, step))",
          "legendFormat": "{{journey}} - {{step}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Step CLS Trend",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "avg(synthetic_step_cls{env=~\"$env\", run_id=~\"$run_id\"}) by (journey, step)",
          "legendFormat": "{{journey}} - {{step}}"
        }
      ]
    }

  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s"
}
