{
  "title": "Synthetic URL Monitoring (Filtered)",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "query",
        "label": "Environment",
        "datasource": "Prometheus",
        "query": "label_values(synthetic_url_success_total, env)",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "run_id",
        "type": "query",
        "label": "Run ID",
        "datasource": "Prometheus",
        "query": "label_values(synthetic_url_success_total{env=~\"$env\"}, run_id)",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Overall P90 (Full Run)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(synthetic_url_duration_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[$__range])) by (le))",
          "legendFormat": "P90"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Overall Avg (Full Run)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(synthetic_url_duration_s_sum{env=~\"$env\", run_id=~\"$run_id\"}[$__range])) / sum(rate(synthetic_url_duration_s_count{env=~\"$env\", run_id=~\"$run_id\"}[$__range]))",
          "legendFormat": "AVG"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Success",
      "gridPos": { "x": 12, "y": 0, "w": 3, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(synthetic_url_success_total{env=~\"$env\", run_id=~\"$run_id\"}[$__range]))",
          "legendFormat": "Success"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Failure",
      "gridPos": { "x": 15, "y": 0, "w": 3, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(synthetic_url_failure_total{env=~\"$env\", run_id=~\"$run_id\"}[$__range]))",
          "legendFormat": "Failure"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "URL Average Trend",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(synthetic_url_duration_s_sum{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (scenario) / sum(rate(synthetic_url_duration_s_count{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (scenario)",
          "legendFormat": "{{scenario}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "URL P90 Trend",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(synthetic_url_duration_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (le, scenario))",
          "legendFormat": "{{scenario}}"
        }
      ]
    },

    {
      "type": "table",
      "title": "Top Slowest URLs (P90)",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.9, sum(rate(synthetic_url_duration_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (le, scenario)))",
          "format": "table",
          "legendFormat": "{{scenario}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "FCP Trend",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(synthetic_url_fcp_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (le, scenario))",
          "legendFormat": "{{scenario}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "LCP Trend",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(synthetic_url_lcp_s_bucket{env=~\"$env\", run_id=~\"$run_id\"}[5m])) by (le, scenario))",
          "legendFormat": "{{scenario}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "CLS Trend",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "avg(synthetic_url_cls{env=~\"$env\", run_id=~\"$run_id\"}) by (scenario)",
          "legendFormat": "{{scenario}}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s"
}
